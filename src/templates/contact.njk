{% extends "layout.njk" %}

{% set page = {
  title: "Contact Us",
  description: "Get in touch with SpaceSmart Guide - questions, corrections, product suggestions, or partnership inquiries.",
  canonicalUrl: site.url + "/contact/",
  ogImage: seo.default_image
} %}

{% block content %}
<section class="container" style="max-width: 700px;">
  <header style="text-align: center; margin-bottom: 3rem; padding-top: 2rem;">
    <h1>Contact SpaceSmart Guide</h1>
    <p class="text-muted" style="font-size: 1.25rem;">We read every message — really.</p>
  </header>

  <article class="article-body">
    <h2>General Inquiries</h2>
    <p>
      Found a factual error? Have a product suggestion? Want to share your dorm/apartment experience?
      Email us at <a href="mailto:team@spacesmartguide.com">team@spacesmartguide.com</a>.
    </p>

    <h2>Corrections & Updates</h2>
    <p>
      We aim for accuracy but things change — prices, availability, product specs. 
      If you spot something outdated or incorrect, please include:
    </p>
    <ul>
      <li>Article URL</li>
      <li>What needs correction</li>
      <li>Source (if applicable)</li>
    </ul>

    <h2>Product Suggestions</h2>
    <p>
      Know a great piece of gear for small spaces that we missed? Tell us:
    </p>
    <ul>
      <li>Product name + link</li>
      <li>Category (dorm, apartment, tiny kitchen)</li>
      <li>Why it deserves a spot</li>
    </ul>

    <h2>Partnership Inquiries</h2>
    <p>
      We're selective about partnerships. We only work with brands whose products we'd genuinely recommend.
      No sponsored content, no paid reviews. Affiliate programs welcome — email <a href="mailto:partners@spacesmartguide.com">partners@spacesmartguide.com</a>.
    </p>

    <h2>Press & Media</h2>
    <p>
      Media kit, logos, and press contact: <a href="mailto:press@spacesmartguide.com">press@spacesmartguide.com</a>.
    </p>

    <hr style="border: none; border-top: 1px solid var(--color-border); margin: 2rem 0;">

    <p style="color: var(--color-text-muted); font-size: 0.875rem;">
      <strong>SpaceSmart Guide</strong><br>
      Smart Gear for Small Spaces<br>
      <a href="https://github.com/Tanix420/spacesmart-guide">GitHub</a> • 
      <a href="{{ site.url }}/about/">About</a> • 
      <a href="{{ site.url }}/methodology/">Methodology</a> • 
      <a href="{{ site.url }}/privacy/">Privacy Policy</a>
    </p>
  </article>
</section>
{% endblock %}