{% extends "layout.njk" %}

{% block content %}
<div class="container" style="text-align: center; padding: var(--space-3xl) 0;">
  <h1 style="font-size: 6rem; color: var(--color-text-muted); margin: 0; line-height: 1;">404</h1>
  <h2 style="margin: var(--space-lg) 0; color: var(--color-text);">Page Not Found</h2>
  <p style="font-size: 1.25rem; color: var(--color-text-muted); max-width: 600px; margin: 0 auto var(--space-xl);">
    Sorry, we couldn't find that page. It might have been moved or doesn't exist.
  </p>
  
  <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; margin-bottom: var(--space-2xl);">
    <a href="{{ site.url }}/" class="btn btn-primary btn-lg">← Back Home</a>
    <a href="{{ site.url }}/search/" class="btn btn-outline btn-lg">Search Guides</a>
  </div>

  <div style="max-width: 600px; margin: 0 auto; text-align: left;">
    <h3 style="margin-bottom: var(--space-md);">Popular Categories</h3>
    <div class="category-grid" style="justify-content: center;">
      {% for cat in config.content.categories %}
      <a href="{{ site.url }}/{{ cat.id }}/" class="category-card" style="max-width: 280px;">
        <h3>{{ cat.name }}</h3>
        <p>{{ cat.description }}</p>
      </a>
      {% endfor %}
    </div>
  </div>

  <hr style="border: none; border-top: 1px solid var(--color-border); margin: var(--space-2xl) 0;">
  
  <p style="color: var(--color-text-muted);">
    <a href="{{ site.url }}/search/" style="color: var(--color-primary);">Search all guides →</a>
  </p>
</div>
{% endblock %}