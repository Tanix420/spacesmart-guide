<div class="product-card" itemscope itemtype="https://schema.org/Product">
  <link itemprop="url" href="{{ product.affiliateUrl }}">

  {% if product.image %}
  <a href="{{ product.affiliateUrl }}" class="product-card-image-link" target="_blank" rel="noopener sponsored" aria-label="{{ product.name }} - View on Amazon">
    <img src="{{ product.image }}" alt="{{ product.name }} - {{ product.shortDesc }}" class="product-card-image" itemprop="image" loading="lazy">
  </a>
  {% endif %}

  <div class="product-card-info">
    {% if product.badge %}
    <span class="product-card-badge badge-{{ product.badge }}">{{ product.badgeLabel }}</span>
    {% endif %}

    <h3 class="product-card-title" itemprop="name">{{ product.name }}</h3>

    {% if product.rating %}
    <div class="product-card-rating" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
      <span class="stars" aria-label="{{ product.rating }} out of 5 stars">
        {% set fullStars = product.rating | int | default(0) %}
        {% set hasHalf = (product.rating - fullStars) >= 0.5 %}
        {% for i in range(5) %}
        {% if i < fullStars %}★{% elif i == fullStars and hasHalf %}☆{% else %}☆{% endif %}
        {% endfor %}
      </span>
      <span itemprop="ratingValue">{{ product.rating }}</span>
      <span itemprop="reviewCount">{{ product.reviewCount }}</span>
      <span class="review-count">({{ product.reviewCount | number }}+ reviews)</span>
    </div>
    {% endif %}

    <div class="product-card-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <meta itemprop="priceCurrency" content="USD">
      <meta itemprop="price" content="{{ product.price }}">
      <meta itemprop="availability" content="{% if product.inStock %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
      {{ product.priceDisplay }}
    </div>

    <a href="{{ product.affiliateUrl }}" class="product-card-cta" target="_blank" rel="noopener sponsored" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 15l-6-6-6 6"/>
      </svg>
      View on Amazon
    </a>
  </div>
</div>