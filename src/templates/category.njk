{% extends "layout.njk" %}

{% block content %}
<!-- Category Hero -->
<section class="container" style="padding-top: 2rem; padding-bottom: 2rem;">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="{{ site.url }}/">Home</a>
    <span class="separator">/</span>
    <span class="current">{{ category.name }}</span>
  </nav>

  <header style="text-align: center; max-width: 800px; margin: 0 auto 3rem;">
    <span class="article-category">{{ category.name }}</span>
    <h1 style="margin-top: 1rem;">{{ category.name }}</h1>
    <p class="article-intro">{{ category.description }}</p>
  </header>
</section>

<!-- Articles Grid -->
<section class="container" aria-labelledby="guides-heading">
  <div class="category-grid">
    {% for article in articles %}
    <a href="{{ site.url }}/{{ article.category }}/{{ article.slug }}/" class="category-card">
      {% if article.ogImage %}
      <img src="{{ article.ogImage }}" alt="{{ article.title }} - {{ article.excerpt }}" class="category-card-image" loading="lazy" style="width: 100%; height: 160px; object-fit: cover; border-radius: var(--radius-md); margin-bottom: 1rem;">
      {% endif %}
      <h3>{{ article.title }}</h3>
      <p>{{ article.excerpt }}</p>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border);">
        <span class="text-sm text-muted">{{ formatDate(article.date) }}</span>
        <span class="text-sm font-medium">Read Guide →</span>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

{% if articles.length > 12 %}
<div class="text-center" style="margin-top: 3rem;">
  <a href="{{ site.url }}/search/" class="btn btn-outline btn-lg">View All Guides</a>
</div>
{% endif %}

<!-- Newsletter -->
<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="container">
    <div class="newsletter-content">
      <h2 id="newsletter-heading">Don't Miss a Deal</h2>
      <p>Weekly roundup of the best small space finds, price drops, and new guides.</p>
      <form class="newsletter-form" action="#" method="POST">
        <input type="email" class="newsletter-input" placeholder="your@email.com" required aria-label="Email address">
        <button type="submit" class="btn btn-accent">Subscribe</button>
      </form>
    </div>
  </div>
</section>
{% endblock %}